ntend\\src\\pages\\login\\Login.jsx",["92"],[],"import React from \"react\";\r\nimport bootstrap from \"bootstrap\";\r\nimport \"../login/style.css\"\r\n\r\nconst Login = () => {\r\n  return (\r\n    <>\r\n      <section className=\"container\">\r\n        <div className=\"sub_container\">\r\n          <div className=\"login_heading \">\r\n            <h1 className=\"login_heading__text\">Log In</h1>\r\n          </div>\r\n          <div className=\"login_username\">\r\n            <span className=\"login_username__text\">Username</span>\r\n          </div>\r\n          <div className=\"login_username__input\">\r\n            <input type=\"text\" className=\"login_username__input__text\" placeholder=\"Username\" />\r\n          </div>\r\n          <div className=\"login_password\">\r\n            <span className=\"login_password__text\">Password</span>\r\n          </div>\r\n          <div className=\"login_password__input\">\r\n            <input type=\"password\" className=\"login_password__input__text\" placeholder=\"Password\" />\r\n          </div>\r\n          <div className=\"login_submit\">\r\n            <button className=\"login_submit__button\">Log In</button>\r\n          </div>\r\n          <div className=\"signup\">\r\n            <button className=\"signup_button\">Sign Up</button>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\nexport default Login;\r\n","C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\pages\\home\\Home.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\router\\Router.jsx",["93"],[],"import React from \"react\"\r\nimport {Route, BrowserRouter as Router, Routes} from \"react-router-dom\";\r\nimport Home from '../pages/home/Home';\r\nimport Login from '../pages/login/Login'\r\nimport Signup from \"../pages/signup/Signup\";\r\n\r\n\r\nconst Routers=()=>{\r\n            return(\r\n            \r\n            <Router>\r\n                        <Routes>\r\n                       \r\n                        <Route  exact path=\"/login\" component={<Login/>}/>\r\n                        <Route  exact path=\"/signup\" component={<Signup/>}/>\r\n                        </Routes>\r\n                       \r\n            </Router>\r\n            )\r\n    \r\n}\r\nexport default Routers;","C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\header\\Header.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\footer\\Footer.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\main\\Main.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\card\\Card.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\article\\Article.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\sidebar\\Sidebar.jsx",["94"],[],"import React from \"react\";\r\nimport{Sidebar,Menu,MenuItem} from \"react-pro-sidebar\";\r\n\r\nimport \"./sidebar_style.css\";\r\nimport { FaAngleDoubleLeft, FaAngleDoubleRight } from \"react-icons/fa\";\r\nconst Sidebars = ({collapsed,toggled,handleToggleSidebar,HandleCollapsedChange}) => {\r\n            return (\r\n              <>\r\n              <div className=\"nav_container\">\r\n                <Sidebar\r\n                  collapsed={collapsed}\r\n                  toggled={toggled}\r\n                  breakPoint=\"md\"\r\n                  onToggle={handleToggleSidebar}\r\n                  onCollapse={HandleCollapsedChange}\r\n                >\r\n                  <Menu iconShape=\"circle\">\r\n                    {collapsed ? (\r\n                      <MenuItem\r\n                        icon={<FaAngleDoubleRight />}\r\n                        onClick={HandleCollapsedChange}\r\n                      ></MenuItem>\r\n                    ) : (\r\n                      <MenuItem\r\n                        suffix={<FaAngleDoubleLeft />}\r\n                        onClick={HandleCollapsedChange}\r\n                      >\r\n                        <div\r\n                          style={{\r\n                            padding: \"9px\",\r\n                            textTransform: \"uppercase\",\r\n                            fontWeight: \"bold\",\r\n                            fontSize: 15,\r\n                            letterSpacing: \"1px\",\r\n                          }}\r\n                        >\r\n                          Admin Dashboard\r\n                        </div>\r\n                      </MenuItem>\r\n                    )}\r\n                    ;\r\n                  </Menu>\r\n                  <Menu iconShape=\"circle\">\r\n                    <MenuItem icon={<FaAngleDoubleRight />}>\r\n                      Dashboard \r\n                    </MenuItem>\r\n                    <MenuItem icon={<FaAngleDoubleRight />}>\r\n                      Dashboard \r\n                    </MenuItem>\r\n                    <MenuItem icon={<FaAngleDoubleRight />}>\r\n                      Dashboard \r\n                    </MenuItem>\r\n                    <MenuItem icon={<FaAngleDoubleRight />}>\r\n                      Dashboard \r\n                    </MenuItem>\r\n                    <MenuItem icon={<FaAngleDoubleRight />}>\r\n                      Dashboard \r\n                    </MenuItem>\r\n                  </Menu>\r\n\r\n                  <Menu iconShape=\"circle\">\r\n                    <MenuItem icon={<FaAngleDoubleRight />}>\r\n                      Dashboard \r\n                    </MenuItem>\r\n                  </Menu>\r\n                  \r\n                </Sidebar>\r\n                </div>\r\n              </>\r\n            );};\r\n\r\nexport default Sidebars;\r\n            ",[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\components\\button\\button.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\\frontend\\src\\features\\Slidder.jsx",[],[],"C:\\Users\\sunny\\Desktop\\Project\\set6\